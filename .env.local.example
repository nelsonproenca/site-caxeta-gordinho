# Copy to .env.local and fill in with your Supabase project's values
# (Project Settings > API in the Supabase dashboard, or `supabase status`
# for local dev). See prd.md §8.2.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-side only — bypasses RLS. Never expose to the client/browser.
SUPABASE_SERVICE_ROLE_KEY=

NEXT_PUBLIC_SITE_URL=http://localhost:3000
